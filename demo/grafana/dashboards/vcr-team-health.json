    {
      "id": 7,
      "type": "timeseries",
      "title": "Weekly LLM Cost (USD)",
      "description": "Total LLM spend per week across all PRs reviewed. Stable low cost is the goal.",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 7 },
      "datasource": { "type": "testdata", "uid": "testdata-vcr" },
      "targets": [
        {
          "refId": "A",
          "scenarioId": "csv_content",
          "alias": "Weekly cost (USD)",
          "csvContent": "time,Cost\n2026-01-05T00:00:00Z,4.20\n2026-01-12T00:00:00Z,5.80\n2026-01-19T00:00:00Z,4.90\n2026-01-26T00:00:00Z,6.10\n2026-02-02T00:00:00Z,5.30\n2026-02-09T00:00:00Z,4.70\n2026-02-16T00:00:00Z,5.50\n2026-02-23T00:00:00Z,4.80\n2026-03-02T00:00:00Z,5.20\n2026-03-09T00:00:00Z,4.60\n2026-03-16T00:00:00Z,5.10\n2026-03-23T00:00:00Z,4.90"

      "datasource": { "type": "testdata", "uid": "testdata-vcr" },
      "targets": [
        {
          "refId": "A",
          "scenarioId": "csv_content",
          "alias": "L3 Trigger Rate (%)",
          "csvContent": "time,L3 Trigger Rate\n2026-01-05T00:00:00Z,28\n2026-01-12T00:00:00Z,31\n2026-01-19T00:00:00Z,29\n2026-01-26T00:00:00Z,35\n2026-02-02T00:00:00Z,38\n2026-02-09T00:00:00Z,42\n2026-02-16T00:00:00Z,40\n2026-02-23T00:00:00Z,37\n2026-03-02T00:00:00Z,39\n2026-03-09T00:00:00Z,41\n2026-03-16T00:00:00Z,38\n2026-03-23T00:00:00Z,36"

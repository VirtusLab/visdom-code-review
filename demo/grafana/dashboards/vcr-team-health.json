{
  "id": null,
  "uid": "vcr-team-health",
  "title": "VCR Team Health",
  "description": "Visdom Code Review — team health metrics. Shows PR cycle time, finding quality, and cost trends.",
  "tags": ["visdom", "code-review", "team-health"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 38,
  "version": 1,
  "refresh": "",
  "time": { "from": "now-12w", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "PR Cycle Time (hours, open → merge)",
      "description": "Time from PR open to merge. VCR deployed at marker — reviewers spend less time triaging noise, high-risk PRs get escalated faster.",
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 9 },
      "datasource": { "type": "testdata", "uid": "testdata-vcr" },
      "targets": [
        {
          "refId": "A",
          "scenarioId": "csv_content",
          "alias": "Without VCR (baseline)",
          "csvContent": "time,Without VCR\n2026-01-05T00:00:00Z,71\n2026-01-12T00:00:00Z,68\n2026-01-19T00:00:00Z,74\n2026-01-26T00:00:00Z,70\n2026-02-02T00:00:00Z,69\n2026-02-09T00:00:00Z,73\n2026-02-16T00:00:00Z,68\n2026-02-23T00:00:00Z,71\n2026-03-02T00:00:00Z,72\n2026-03-09T00:00:00Z,70\n2026-03-16T00:00:00Z,69\n2026-03-23T00:00:00Z,73"
        },
        {
          "refId": "B",
          "scenarioId": "csv_content",
          "alias": "With VCR",
          "csvContent": "time,With VCR\n2026-01-05T00:00:00Z,71\n2026-01-12T00:00:00Z,68\n2026-01-19T00:00:00Z,74\n2026-01-26T00:00:00Z,70\n2026-02-02T00:00:00Z,52\n2026-02-09T00:00:00Z,41\n2026-02-16T00:00:00Z,34\n2026-02-23T00:00:00Z,27\n2026-03-02T00:00:00Z,21\n2026-03-09T00:00:00Z,17\n2026-03-16T00:00:00Z,14\n2026-03-23T00:00:00Z,12"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "none",
            "pointSize": 5,
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "red", "value": 48 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Without VCR" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#6b7280" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "With VCR" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Avg Cost / PR",
      "description": "Average LLM cost per pull request across all layers.",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "testdata", "uid": "testdata-vcr" },
      "targets": [
        {
          "refId": "A",
          "scenarioId": "manual_entry",
          "points": [[0, 1734480000000]]
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "$0.09" } } }],
          "color": { "mode": "fixed", "fixedColor": "#10b981" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "False Positive Rate",
      "description": "Percentage of findings that were rejected by developers as noise.",
      "gridPos": { "x": 16, "y": 3, "w": 4, "h": 3 },
      "datasource": { "type": "testdata", "uid": "testdata-vcr" },
      "targets": [
        {
          "refId": "A",
          "scenarioId": "manual_entry",
          "points": [[0, 1734480000000]]
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "11.2%" } } }],
          "color": { "mode": "fixed", "fixedColor": "#10b981" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Acceptance Rate",
      "description": "Percentage of VCR findings acted on by developers (fixed, acknowledged, or converted to ticket).",
      "gridPos": { "x": 16, "y": 6, "w": 4, "h": 3 },
      "datasource": { "type": "testdata", "uid": "testdata-vcr" },
      "targets": [
        {
          "refId": "A",
          "scenarioId": "manual_entry",
          "points": [[0, 1734480000000]]
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "78%" } } }],
          "color": { "mode": "fixed", "fixedColor": "#10b981" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "barchart",
      "title": "Issues Found by Severity (weekly)",
      "description": "More CRITICAL/HIGH findings found early = fewer production incidents.",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 9 },
      "datasource": { "type": "testdata", "uid": "testdata-vcr" },
      "targets": [
        {
          "refId": "A",
          "scenarioId": "csv_content",
          "csvContent": "Week,Critical,High,Medium,Low\nW1,3,8,12,19\nW2,5,11,15,22\nW3,4,9,13,20\nW4,6,12,16,24\nW5,4,10,14,20\nW6,5,9,13,21\nW7,3,11,12,18\nW8,4,8,14,19"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 80 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Critical" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }]
          },
          {
            "matcher": { "id": "byName", "options": "High" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f59e0b" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Medium" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#3b82f6" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Low" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#6b7280" } }]
          }
        ]
      },
      "options": {
        "xField": "Week",
        "stacking": "normal",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" },
        "xTickLabelRotation": 0
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "L3 Deep Review Trigger Rate",

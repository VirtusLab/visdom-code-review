      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 8,
      "type": "gauge",
      "title": "Issue Tracking Score (ITS)",
      "description": "VISDOM SDLC composite: finding_acceptance × (1 − fpr) × recall. Target ≥ 0.70.",
      "gridPos": { "x": 12, "y": 18, "w": 6, "h": 7 },
      "datasource": { "type": "testdata", "uid": "testdata-vcr" },
      "targets": [
        {
          "refId": "A",
          "scenarioId": "manual_entry",
          "points": [[0, 1734480000000]]
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizWidth": 75,
        "minVizHeight": 75

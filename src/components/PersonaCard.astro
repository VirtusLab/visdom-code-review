---
interface Props {
  name: string;
  role: string;
  color?: 'green' | 'blue' | 'purple' | 'amber' | 'red';
}

const { name, role, color = 'green' } = Astro.props;

const borderColors = {
  green: 'border-l-emerald-500',
  blue: 'border-l-blue-500',
  purple: 'border-l-purple-500',
  amber: 'border-l-amber-500',
  red: 'border-l-red-500',
};

const badgeColors = {
  green: 'bg-emerald-100 text-emerald-700',
  blue: 'bg-blue-100 text-blue-700',
  purple: 'bg-purple-100 text-purple-700',
  amber: 'bg-amber-100 text-amber-700',
  red: 'bg-red-100 text-red-700',
};
---
<div class={`bg-white border border-visdom-gray-200 border-l-4 ${borderColors[color]} rounded-lg p-5 mb-5`}>
  <div class="flex items-center gap-2.5 mb-3">
    <span class="font-bold text-visdom-gray-900 text-sm">{name}</span>
    <span class={`text-xs px-2.5 py-0.5 rounded-full font-medium ${badgeColors[color]}`}>{role}</span>
  </div>
  <div class="text-sm text-visdom-gray-500 leading-relaxed [&>p]:!mb-1.5 [&>p:last-child]:!mb-0">
    <slot />
  </div>
</div>

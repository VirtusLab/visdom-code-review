---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<div class="mb-8">
  <h3>{title}</h3>
  <div class="grid md:grid-cols-2 gap-4">
    <div class="border border-red-200 bg-red-50/50 rounded-lg p-4">
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-red-100 text-red-700">BEFORE</span>
      </div>
      <div class="text-sm text-visdom-gray-600 [&>p]:!mb-2 [&>ol]:list-decimal [&>ol]:pl-4 [&>ol]:space-y-1 [&>ol]:text-sm [&>ol]:text-visdom-gray-600 [&_strong]:text-visdom-gray-800">
        <slot name="before" />
      </div>
    </div>
    <div class="border border-emerald-200 bg-emerald-50/50 rounded-lg p-4">
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-emerald-100 text-emerald-700">AFTER</span>
      </div>
      <div class="text-sm text-visdom-gray-600 [&>p]:!mb-2 [&>ol]:list-decimal [&>ol]:pl-4 [&>ol]:space-y-1 [&>ol]:text-sm [&>ol]:text-visdom-gray-600 [&_strong]:text-visdom-gray-800">
        <slot name="after" />
      </div>
    </div>
  </div>
</div>

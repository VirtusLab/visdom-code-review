---
interface Props {
  title: string;
  description: string;
  href: string;
  tag?: string;
  tagColor?: 'green' | 'blue' | 'amber' | 'red' | 'purple';
  source?: string;
}

const { title, description, href, tag, tagColor = 'green', source } = Astro.props;

const tagColors = {
  green: 'bg-emerald-100 text-emerald-700 border-emerald-200',
  blue: 'bg-blue-100 text-blue-700 border-blue-200',
  amber: 'bg-amber-100 text-amber-700 border-amber-200',
  red: 'bg-red-100 text-red-700 border-red-200',
  purple: 'bg-purple-100 text-purple-700 border-purple-200',
};

const topColors = {
  green: 'border-t-emerald-500',
  blue: 'border-t-blue-500',
  amber: 'border-t-amber-500',
  red: 'border-t-red-500',
  purple: 'border-t-purple-500',
};
---
<a href={href} target="_blank" rel="noopener" class:list={['block bg-white border border-visdom-gray-200 border-t-2 rounded-lg p-5 hover:shadow-md transition-shadow no-underline group', topColors[tagColor]]}>
  {tag && (
    <span class={`inline-block text-xs px-2 py-0.5 rounded border font-medium mb-2 ${tagColors[tagColor]}`}>
      {tag}
    </span>
  )}
  <h4 class="text-sm font-semibold text-visdom-gray-900 group-hover:text-visdom-green mb-1.5">{title}</h4>
  <p class="text-xs text-visdom-gray-500 leading-relaxed !mb-0 line-clamp-3">{description}</p>
  {source && <p class="text-xs text-visdom-gray-400 !mb-0 mt-3">{source}</p>}
</a>

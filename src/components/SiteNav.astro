---
/**
 * Site-wide navigation wrapper.
 * Uses the same markup as the landing page nav for visual consistency.
 * The DS Nav component has a fixed position and default "Visdom" brand
 * that doesn't match our site — this Astro component gives us full control.
 */
import VirtusLabLogo from './VirtusLabLogo.astro';
import VisdomBrand from './VisdomBrand.astro';

interface Props {
  activeLink?: string;
}

const { activeLink } = Astro.props;
const base = import.meta.env.BASE_URL;

const links = [
  { label: 'Home', href: `${base}` },
  { label: 'For Leaders', href: `${base}guide/leaders/` },
  { label: 'For Engineers', href: `${base}guide/platform-engineers/` },
  { label: 'For Developers', href: `${base}guide/developers/` },
  { label: 'Scenarios', href: `${base}before-after/` },
  { label: 'FAQ', href: `${base}faq/` },
  { label: 'Reference', href: `${base}reference/` },
];
---

<!-- VirtusLab Top Bar -->
<div class="site-topbar">
  <div class="site-topbar__inner">
    <a href="https://virtuslab.com" class="site-topbar__link">
      <VirtusLabLogo className="h-4 w-auto text-gray-400" />
    </a>
  </div>
</div>

<!-- Navigation -->
<nav class="site-nav">
  <div class="site-nav__inner">
    <VisdomBrand product="Code Review" href={base} />
    <div class="site-nav__links">
      {links.map(link => (
        <a href={link.href} class:list={['site-nav__link', activeLink === link.label && 'site-nav__link--active']}>
          {link.label}
        </a>
      ))}
      <a href="https://github.com/VirtusLab/visdom-code-review" class="site-nav__cta">GitHub</a>
    </div>
  </div>
</nav>

<style>
  .site-topbar {
    background: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
  }
  .site-topbar__inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0.375rem 1.5rem;
  }
  .site-topbar__link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.15s;
  }
  .site-topbar__link:hover {
    opacity: 1;
  }

  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #e5e7eb;
  }
  .site-nav__inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }
  .site-nav__links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }
  .site-nav__link {
    font-size: 0.875rem;
    color: #6b7280;
    text-decoration: none;
    transition: color 0.15s;
  }
  .site-nav__link:hover,
  .site-nav__link--active {
    color: #111827;
  }
  .site-nav__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid #d1d5db;
    color: #374151;
    text-decoration: none;
    transition: all 0.15s;
  }
  .site-nav__cta:hover {
    background: #f3f4f6;
    border-color: #9ca3af;
  }
</style>

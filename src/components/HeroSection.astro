---
import { HeroSection as HeroSectionReact } from '@virtuslab/visdom-ui';

interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;

const stats = [
  { value: '<10 min', label: 'to first feedback', detail: 'vs 24-48h human review' },
  { value: '-40%', label: 'senior review time', detail: 'pre-annotated, focused PRs' },
  { value: '$0.05', label: 'per LOW-risk PR', detail: 'layered cost model' },
];
---
<HeroSectionReact title={title} subtitle={subtitle} stats={stats} variant="dark" />

    href={`${base}architecture/`}
    tag="DOCS"
    tagColor="green"
  />
  <ResourceCard
    title="Before / After"
    description="4 concrete scenarios showing what changes with VCR."
    href={`${base}before-after/`}
    tag="SCENARIOS"
    tagColor="blue"
  />
  <ResourceCard
    title="Configuration"

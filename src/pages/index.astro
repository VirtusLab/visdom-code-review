---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatCard from '../components/StatCard.astro';
import PersonaCard from '../components/PersonaCard.astro';
import ResourceCard from '../components/ResourceCard.astro';
import Callout from '../components/Callout.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import '../styles/landing.css';

const base = import.meta.env.BASE_URL;

const faqTeaseItems = [
  {
    question: "How do I know the findings are real, not hallucinations?",
    answer: "Layer 1 uses deterministic regex rules that cannot hallucinate. AI layers (L2/L3) require \u226580% confidence and cap at 3 findings per lens. Verified on 50 real-world PRs across 5 languages with an independent LLM judge.",
  },
  {
    question: "Does our code leave the network?",
    answer: "No. VCR runs in your CI/CD pipeline with your own API key. No SaaS dependency. Air-gap compatible \u2014 Layer 1 works with zero network access.",
  },
  {
    question: "What does it actually cost?",
    answer: "~$0.10 per PR average. Low-risk PRs cost $0.02 (Haiku triage only). A 50-person team doing 500 PRs/week pays ~$2,600/year in LLM costs vs $7,200\u2013$24,000 for SaaS tools.",
  },
];
---
<BaseLayout title="Visdom Code Review">

  <!-- ============ Hero Section ============ -->
  <section class="hero">
    <div class="hero__inner">
      <h1 class="hero__headline">
        Visdom<br />
        <span class="hero__gradient">Code Review</span>
      </h1>
      <p class="hero__subtitle">
        A multi-layered review process for enterprise teams shipping AI-generated code.
        Part of the Visdom AI-Native SDLC.
      </p>
      <div class="hero__buttons">
        <a href={`${base}guide/leaders/`} class="btn btn--primary">For Leaders</a>
        <a href={`${base}reference/`} class="btn btn--outline">Technical Reference</a>
        <a href="https://github.com/VirtusLab/visdom-code-review/tree/master/demo" class="btn btn--outline">Run it yourself</a>
      </div>
      <p class="hero__tagline">Part of <a href="https://virtuslab.com/services/visdom" class="hero__tagline-link">Visdom</a> · VirtusLab's AI-Native SDLC</p>

      <!-- Pipeline strip -->
      <div class="pipeline">
        <div class="pipeline__stage">
          <span class="pipeline__label">L0</span>
          <span class="pipeline__name">Triage</span>
        </div>
        <span class="pipeline__arrow">&rarr;</span>
        <div class="pipeline__stage">
          <span class="pipeline__label">L1</span>
          <span class="pipeline__name">Static</span>
        </div>
        <span class="pipeline__arrow">&rarr;</span>
        <div class="pipeline__stage">
          <span class="pipeline__label">L2</span>
          <span class="pipeline__name">Semantic</span>
        </div>
        <span class="pipeline__arrow">&rarr;</span>
        <div class="pipeline__stage">
          <span class="pipeline__label">L3</span>
          <span class="pipeline__name">Deep Analysis</span>
        </div>
        <span class="pipeline__arrow">&rarr;</span>
        <div class="pipeline__stage pipeline__stage--reporter">
          <span class="pipeline__label">R</span>
          <span class="pipeline__name">Reporter</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Stats Section ============ -->
  <section class="stats-section">
    <div class="stats-section__inner">
      <h2 class="section-heading">The problem in numbers</h2>
      <p class="section-subtitle">
        Your CI says the code is fine. Your tests pass. But the AI wrote the tests too.
      </p>
      <div class="grid sm:grid-cols-3 gap-4">
        <StatCard
          value="84%"
          label="of CI test failures are flaky, not real regressions"
          source="Google"
          color="red"
        />
        <StatCard
          value="45%"
          label="of AI-generated code contains OWASP security vulnerabilities"
          source="Veracode 2025"
          color="amber"
        />
        <StatCard
          value="12.5%"
          label="of agent output that passes CI is still functionally wrong"
          source="Spotify"
          color="purple"
        />
      </div>
    </div>
  </section>

  <!-- ============ VCR Difference ============ -->
  <section class="feature-row feature-row--offwhite">
    <div class="feature-row__inner feature-row__inner--flipped">
      <div class="feature-row__text">
        <span class="kicker">A different approach</span>
        <h2 class="feature-row__heading">A review process you deploy into your platform</h2>
        <p class="feature-row__desc">
          VCR is not a SaaS product and not a vendor service. It's a review <em>process</em> with an
          open-source reference implementation &mdash; opinionated patterns, six runnable layers, and
          a pipeline you run inside your own CI/CD, against your own LLM provider, behind your own network boundary.
        </p>
        <p class="feature-row__desc">
          VirtusLab deploys VCR as part of Visdom engagements: we embed with your platform engineers,
          configure the pipeline for your stack, tune the lenses to your conventions, and hand it over.
          Capability transfer from day one. Your team owns and operates the process. No ongoing SaaS dependency.
        </p>
        <a href={`${base}reference/evaluation/`} class="feature-row__link">Evaluation methodology &rarr;</a>
      </div>
      <div class="feature-row__visual">
        <div class="card">
          <p class="card__label">Deployment model</p>
          <div class="diff-table">
            <div class="diff-table__header">
              <span></span>
              <span class="diff-table__col-head">SaaS review tools</span>
              <span class="diff-table__col-head diff-table__col-head--vcr">VCR (deployed)</span>
            </div>
            <div class="diff-table__row">
              <span class="diff-table__label">Where it runs</span>
              <span>Vendor cloud</span>
              <span class="diff-table__vcr">Your CI/CD pipeline</span>
            </div>
            <div class="diff-table__row">
              <span class="diff-table__label">LLM provider</span>
              <span>Vendor-chosen</span>
              <span class="diff-table__vcr">Your choice (Claude, GPT, self-hosted)</span>
            </div>
            <div class="diff-table__row">
              <span class="diff-table__label">Code leaves your network</span>
              <span>Yes</span>
              <span class="diff-table__vcr">No &mdash; runs on your infra</span>
            </div>
            <div class="diff-table__row">
              <span class="diff-table__label">Custom review rules</span>
              <span>Limited config</span>
              <span class="diff-table__vcr">Full lens customization (compliance, domain)</span>
            </div>
            <div class="diff-table__row">
              <span class="diff-table__label">Cost model</span>
              <span>Per-seat: $12&ndash;40/dev/mo</span>
              <span class="diff-table__vcr">Your LLM costs only ($0&ndash;0.44/PR)</span>
            </div>
            <div class="diff-table__row">
              <span class="diff-table__label">Ownership</span>
              <span>Vendor dependency</span>
              <span class="diff-table__vcr">Your team owns and operates</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Feature Row 1: How it works (So fast) ============ -->
  <section class="feature-row feature-row--white">
    <div class="feature-row__inner">
      <div class="feature-row__text">
        <span class="kicker">How it works</span>
        <h2 class="feature-row__heading">Layered review</h2>
        <p class="feature-row__desc">
          Every PR passes through layers of increasing depth. Fast and cheap for trivial changes, thorough for risky ones.
          A LOW-risk PR gets feedback in under 2 minutes at ~$0.05.
        </p>
        <a href={`${base}reference/`} class="feature-row__link">Full architecture reference &rarr;</a>
      </div>
      <div class="feature-row__visual">
        <div class="card">
          <div class="card__stages">
            <div class="card__stage">
              <span class="card__num">01</span>
              <span class="card__badge card__badge--green">L0 Triage</span>
              <p class="card__stage-desc">Risk scoring, routing. Instant.</p>
            </div>
            <div class="card__stage">
              <span class="card__num">02</span>
              <span class="card__badge card__badge--blue">L1 Static</span>
              <p class="card__stage-desc">Linters, SAST, pattern checks. &lt;30s.</p>
            </div>
            <div class="card__stage">
              <span class="card__num">03</span>
              <span class="card__badge card__badge--purple">L2 Semantic</span>
              <p class="card__stage-desc">LLM review with full context. &lt;2min.</p>
            </div>
            <div class="card__stage">
              <span class="card__num">04</span>
              <span class="card__badge card__badge--amber">L3 Deep</span>
              <p class="card__stage-desc">Multi-pass analysis, security, arch. &lt;5min.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Feature Row 2: Risk-based (So precise) ============ -->
  <section class="feature-row feature-row--offwhite">
    <div class="feature-row__inner feature-row__inner--flipped">
      <div class="feature-row__text">
        <span class="kicker">Risk-based routing</span>
        <h2 class="feature-row__heading">Risk classification</h2>
        <p class="feature-row__desc">
          Each PR gets a risk level based on path classification, diff size, coverage delta, and module stability.
          Only MEDIUM+ risk triggers deep analysis.
        </p>
        <a href={`${base}before-after/`} class="feature-row__link">See before/after scenarios &rarr;</a>
      </div>
      <div class="feature-row__visual">
        <div class="card">
          <div class="risk-grid">
            <div class="risk-card risk-card--low">
              <span class="risk-card__level">LOW</span>
              <p class="risk-card__desc">Config, docs, deps. Auto-approved or light scan.</p>
            </div>
            <div class="risk-card risk-card--medium">
              <span class="risk-card__level">MEDIUM</span>
              <p class="risk-card__desc">Business logic. Standard LLM review with context.</p>
            </div>
            <div class="risk-card risk-card--high">
              <span class="risk-card__level">HIGH</span>
              <p class="risk-card__desc">Security-sensitive, cross-service. Multi-pass analysis.</p>
            </div>
            <div class="risk-card risk-card--critical">
              <span class="risk-card__level">CRITICAL</span>
              <p class="risk-card__desc">Auth, payments, data migration. Full depth + human gate.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Feature Row 3: Context (So aware) ============ -->
  <section class="feature-row feature-row--white">
    <div class="feature-row__inner">
      <div class="feature-row__text">
        <span class="kicker">Repository context</span>
        <h2 class="feature-row__heading">Context sources</h2>
        <p class="feature-row__desc">
          Each review is fed pre-indexed knowledge about the codebase: ownership, dependencies, commit history, conventions,
          and test reliability data.
        </p>
        <a href="https://github.com/virtuslab/vidia" class="feature-row__link">Explore ViDIA context engine &rarr;</a>
      </div>
      <div class="feature-row__visual">
        <div class="card">
          <p class="card__label">Context sources</p>
          <div class="context-pills">
            <span class="pill pill--green">ViDIA</span>
            <span class="pill pill--blue">Git Blame</span>
            <span class="pill pill--purple">Coverage</span>
            <span class="pill pill--amber">CODEOWNERS</span>
            <span class="pill pill--teal">PR History</span>
            <span class="pill pill--pink">Commit Heatmap</span>
            <span class="pill pill--dashed">+ Your Source</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Feature Row 4: Problems (So honest) ============ -->
  <section class="feature-row feature-row--offwhite">
    <div class="feature-row__inner feature-row__inner--flipped">
      <div class="feature-row__text">
        <span class="kicker">What it catches</span>
        <h2 class="feature-row__heading">AI-code patterns</h2>
        <p class="feature-row__desc">
          Patterns specific to AI-generated code that conventional CI and human reviewers typically miss.
          Each is a dedicated Review Lens in Layer 3.
        </p>
        <a href={`${base}before-after/`} class="feature-row__link">See real examples &rarr;</a>
      </div>
      <div class="feature-row__visual">
        <div class="card">
          <div class="problems-list">
            <div class="problem">
              <span class="problem__num">01</span>
              <div>
                <strong class="problem__title">Circular Tests</strong>
                <p class="problem__desc">Tests that mirror implementation instead of verifying behavior.</p>
              </div>
            </div>
            <div class="problem">
              <span class="problem__num">02</span>
              <div>
                <strong class="problem__title">Hallucinated APIs</strong>
                <p class="problem__desc">Calls to methods or endpoints that don't exist in your codebase.</p>
              </div>
            </div>
            <div class="problem">
              <span class="problem__num">03</span>
              <div>
                <strong class="problem__title">Convention Drift</strong>
                <p class="problem__desc">AI-generated code that ignores your team's established patterns.</p>
              </div>
            </div>
            <div class="problem">
              <span class="problem__num">04</span>
              <div>
                <strong class="problem__title">Over-engineering</strong>
                <p class="problem__desc">Unnecessary Factory patterns, abstractions, and complexity.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ See it in action ============ -->
  <section class="demo-promo">
    <div class="demo-promo__inner">
      <span class="kicker">SEE IT IN ACTION</span>
      <h2 class="demo-promo__heading">Interactive demo — real PRs, real findings</h2>
      <p class="demo-promo__sub">VCR reviews its own codebase on every pull request. Trace the triage flow, see what each layer catches, and follow findings back to the GitHub PR.</p>
      <div class="demo-promo__actions">
        <a href={`${base}demo/`} class="btn btn--primary">Explore the demo →</a>
        <a href="https://vcr-grafana.fly.dev" target="_blank" rel="noopener" class="btn btn--outline">Live Grafana ↗</a>
      </div>
      <div class="demo-promo__screen">
        <div class="gh-preview__bar">
          <span class="gh-preview__dot gh-preview__dot--red"></span>
          <span class="gh-preview__dot gh-preview__dot--yellow"></span>
          <span class="gh-preview__dot gh-preview__dot--green"></span>
          <span class="gh-preview__url">vcr-grafana.fly.dev · Quality Pulse</span>
        </div>
        <img
          src={`${base}screenshots/grafana-dashboard.png`}
          alt="Grafana Quality Pulse dashboard showing VCR metrics"
          class="gh-preview__img"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ============ GitHub Output Preview ============ -->
  <section class="feature-row feature-row--white">
    <div class="feature-row__inner">
      <div class="feature-row__text">
        <span class="kicker">Real output — no toys</span>
        <h2 class="feature-row__heading">What lands on your PR</h2>
        <p class="feature-row__desc">
          Findings grouped by layer, linked to the exact line. Every comment names the rule, the risk level, and a concrete fix — not a vague hint.
        </p>
        <ul class="feature-row__list">
          <li>Layer 1 — deterministic gate: secrets, forbidden patterns, hard rules</li>
          <li>Layer 2 — AI quick scan: logic, reliability, security smell</li>
          <li>Layer 3 — AI deep review: architecture, cache safety, edge cases</li>
        </ul>
        <a href="https://github.com/VirtusLab/visdom-code-review/pull/1" target="_blank" rel="noopener" class="feature-row__link">See the real PR this came from &rarr;</a>
      </div>
      <div class="feature-row__visual">
        <div class="gh-preview__frame">
          <div class="gh-preview__bar">
            <span class="gh-preview__dot gh-preview__dot--red"></span>
            <span class="gh-preview__dot gh-preview__dot--yellow"></span>
            <span class="gh-preview__dot gh-preview__dot--green"></span>
            <span class="gh-preview__url">github.com · Pull Request · VCR commented</span>
          </div>
          <img
            src={`${base}screenshots/github-pr-comment.png`}
            alt="VCR GitHub PR comment showing findings grouped by layer with inline code annotations"
            class="gh-preview__img"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Part of Visdom ============ -->
  <section class="visdom-section">
    <div class="visdom-section__inner">
      <h2 class="section-heading">Part of Visdom</h2>
      <p class="section-subtitle">
        VCR is one of four components in <a href="https://virtuslab.com/services/visdom">Visdom</a>, VirtusLab's AI-Native SDLC.
      </p>
      <div class="visdom-grid">
        <a href="https://github.com/virtuslab/vidia" class="visdom-card">
          <span class="visdom-card__kicker">Context Fabric</span>
          <h4 class="visdom-card__title">ViDIA</h4>
          <p class="visdom-card__desc">Pre-indexed code expertise, dependency graphs, PR history</p>
        </a>
        <div class="visdom-card">
          <span class="visdom-card__kicker">Machine-Speed CI</span>
          <h4 class="visdom-card__title">Fast Feedback</h4>
          <p class="visdom-card__desc">Sub-2-min CI loops, caching, incremental builds, test impact analysis</p>
        </div>
        <a href={`${base}`} class="visdom-card visdom-card--active">
          <span class="visdom-card__kicker visdom-card__kicker--active">Risk Assessment</span>
          <h4 class="visdom-card__title">VCR</h4>
          <p class="visdom-card__desc">Multi-layered AI code review. You are here.</p>
        </a>
        <a href="https://tracevault.dev/" class="visdom-card">
          <span class="visdom-card__kicker">Governance</span>
          <h4 class="visdom-card__title">TraceVault</h4>
          <p class="visdom-card__desc">Audit trail, auto-evaluation, EU AI Act compliance</p>
        </a>
      </div>
      <p class="section-footnote">
        Read the thinking behind it: <a href="https://virtuslab.com/blog/ai/the-fallacy">The AI-Native SDLC series</a>
      </p>
    </div>
  </section>

  <!-- ============ Go Deeper ============ -->
  <section class="deeper-section">
    <div class="deeper-section__inner">
      <h2 class="section-heading">Go deeper</h2>
      <p class="section-subtitle">
        Reference material, architecture docs, and real-world scenarios.
      </p>

      <div class="grid sm:grid-cols-3 gap-3 mb-10">
        <ResourceCard
          title="Before / After Scenarios"
          description="4 concrete scenarios showing what changes when VCR is deployed."
          href={`${base}before-after/`}
          tag="SCENARIOS"
          tagColor="blue"
        />
        <ResourceCard
          title="Technical Reference"
          description="Full architecture, layer docs, configuration, metrics framework."
          href={`${base}reference/`}
          tag="REFERENCE"
          tagColor="purple"
        />
        <ResourceCard
          title="Reference Implementations"
          description="Technology-agnostic table of components and alternatives."
          href={`${base}reference/reference-implementations/`}
          tag="REFERENCE"
          tagColor="green"
        />
      </div>
    </div>
  </section>

  <!-- ============ FAQ Tease ============ -->
  <section class="stats-section">
    <div class="stats-section__inner">
      <h2 class="section-heading">Common questions</h2>

      <div style="max-width: 800px; margin: 0 auto;">
        <FaqAccordion items={faqTeaseItems} />
      </div>

      <div style="text-align: center; margin-top: 1.5rem;">
        <a href={`${base}faq/`} class="btn btn--outline">See all 10 questions &rarr;</a>
      </div>
    </div>
  </section>


  <!-- ============ Run it yourself ============ -->
  <section class="feature-row feature-row--offwhite">
    <div class="feature-row__inner">
      <div class="feature-row__text">
        <span class="kicker">Run it yourself</span>
        <h2 class="feature-row__heading">Self-serve walkthrough on your machine</h2>
        <p class="feature-row__desc">
          Clone the repo and run the pipeline locally against a deliberately flawed PR
          (auth service with 12 passing tests and 94% coverage). The full 4-layer review
          executes end-to-end. No API key needed &mdash; cached responses included.
        </p>
        <a href="https://github.com/VirtusLab/visdom-code-review/tree/master/demo" class="feature-row__link">Setup &amp; commands &rarr;</a>
      </div>
      <div class="feature-row__visual">
        <div class="card">
          <p class="card__label">Quick start</p>
          <pre class="card__code"><code>git clone https://github.com/VirtusLab/visdom-code-review
cd visdom-code-review/demo
npm install

# Narrated walkthrough (auto-paced)
npm run demo:narrate

# Interactive (press Enter to advance)
npm run demo:interactive

# Fast run (no narration)
npm run demo:local</code></pre>
          <div class="demo-results">
            <div class="demo-results__row">
              <span class="demo-results__label">Traditional review</span>
              <span class="demo-results__value">0 findings · 24-48h · ~1h senior eng</span>
            </div>
            <div class="demo-results__row demo-results__row--vcr">
              <span class="demo-results__label">VCR review</span>
              <span class="demo-results__value">14 findings · 2 min · $0.44</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA Section ============ -->
  <section class="cta-section">
    <div class="cta-section__inner">
      <h2 class="cta-section__heading">
        Read the<br /><span class="hero__gradient">full reference</span>
      </h2>
      <p class="cta-section__subtitle">
        Architecture, configuration, metrics framework, and reference implementations.
      </p>
      <div class="hero__buttons">
        <a href={`${base}reference/`} class="btn btn--primary">Technical Reference</a>
        <a href={`${base}before-after/`} class="btn btn--outline">Before / After Scenarios</a>
      </div>
    </div>
  </section>

</BaseLayout>

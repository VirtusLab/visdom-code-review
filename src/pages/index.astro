<h2>From the Field</h2>

<div class="grid sm:grid-cols-2 gap-3 mb-8">
  <ResourceCard
    title="Introducing Roast: Structured AI workflows"
    description="Shopify's open-source framework for structured AI code review — the primary inspiration for VCR's layered approach."
    href="https://shopify.engineering/introducing-roast"
    tag="ARTICLE"
    tagColor="green"
    source="shopify.engineering"
  />
  <ResourceCard
    title="How we built a high-quality AI code review agent"
    description="Augment Code's engineering challenges: false positives, context management, precision vs recall trade-offs."
    href="https://www.augmentcode.com/blog/how-we-built-high-quality-ai-code-review-agent"
    tag="ARTICLE"
    tagColor="green"
    source="augmentcode.com"
  />
  <ResourceCard
    title="Measuring Determinism in LLMs for Code Review"
    description="Academic study on non-determinism: Claude at 0.85 correlation, GPT-4o at 0.79. Why risk classification needs deterministic signals."
    href="https://arxiv.org/html/2502.20747v1"
    tag="RESEARCH"
    tagColor="blue"
    source="arxiv.org"
  />
  <ResourceCard
    title="Spotify Honk: Background Coding Agents"
    description="Spotify's post-mortem on background agents. LLM-as-judge vetoes 25% of agent output — 12.5% structural failure rate."
    href="https://engineering.atspotify.com/2025/12/feedback-loops-background-coding-agents-part-3"
    tag="CASE STUDY"
    tagColor="amber"
    source="engineering.atspotify.com"
  />

<style>
  /* Evaluation Diagram */
  .eval-diagram {
    margin: 2rem 0;
    text-align: center;
  }
  .eval-diagram__row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .eval-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px 24px;
    border-radius: 12px;
    min-width: 80px;
  }
  .eval-box--red { background: #fef2f2; border: 1px solid #fca5a5; }
  .eval-box--green { background: #ecfdf5; border: 1px solid #a7f3d0; }
  .eval-box--gray { background: #f3f4f6; border: 1px solid #d1d5db; }
  .eval-box__num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    font-weight: 700;
  }
  .eval-box--red .eval-box__num { color: #dc2626; }
  .eval-box--green .eval-box__num { color: #059669; }
  .eval-box--gray .eval-box__num { color: #9ca3af; }
  .eval-box__label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
    margin-top: 4px;
  }
  .eval-arrow, .eval-plus {
    font-size: 1.5rem;
    color: #9ca3af;
  }
  .eval-diagram__caption {
    font-size: 0.85rem;
    color: #6b7280;
    margin-top: 12px;
    font-style: italic;
  }

  /* Framework Grid */
  .framework-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin: 1.5rem 0;
  }
  @media (min-width: 768px) {
    .framework-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .framework-card {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 20px;
    background: #fafbfc;
  }
  .framework-card__header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .framework-card__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #10b981;
    color: white;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .framework-card__title {
    font-size: 1rem;
    margin: 0;
  }
  .framework-card__source {
    font-size: 0.75rem;
    color: #9ca3af;
    margin: 0 0 12px;
    font-family: 'JetBrains Mono', monospace;
  }
  .framework-card p { font-size: 0.88rem; }
  .framework-card ul { font-size: 0.88rem; padding-left: 1.2em; }

  /* Classification Legend */
  .classification-legend {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 12px;
  }

---
import '../styles/global.css';

interface Props {
  title: string;
  subtitle?: string;
  section?: string;
  tags?: { label: string; variant?: 'green' | 'gray' | 'outline' }[];
  prev?: { label: string; href: string };
  next?: { label: string; href: string };
}

const { title, subtitle, section, tags = [], prev, next } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Visdom Code Review</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen">
  <!-- Top nav -->
  <nav class="border-b border-visdom-gray-200 bg-white sticky top-0 z-50">
    <div class="max-w-5xl mx-auto px-6 py-3 flex items-center justify-between">
      <a href={`${base}`} class="flex items-center gap-2 text-visdom-gray-900 font-semibold no-underline hover:text-visdom-green-dark">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
        Visdom Code Review
      </a>
      <div class="flex items-center gap-6 text-sm text-visdom-gray-500">
        <a href={`${base}`} class="hover:text-visdom-gray-900 no-underline">Home</a>
        <a href={`${base}guide/leaders/`} class="hover:text-visdom-gray-900 no-underline">For Leaders</a>
        <a href={`${base}guide/platform-engineers/`} class="hover:text-visdom-gray-900 no-underline">For Engineers</a>
        <a href={`${base}guide/developers/`} class="hover:text-visdom-gray-900 no-underline">For Developers</a>
        <a href={`${base}before-after/`} class="hover:text-visdom-gray-900 no-underline">Scenarios</a>
        <a href={`${base}reference/`} class="hover:text-visdom-gray-900 no-underline">Reference</a>
      </div>
    </div>
  </nav>

  <main class="max-w-doc mx-auto px-6 py-10">
    <!-- Breadcrumb -->
    {section && (
      <a href={`${base}`} class="inline-flex items-center gap-1 text-sm text-visdom-gray-500 hover:text-visdom-gray-700 mb-4 no-underline">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        Back to {section}
      </a>
    )}

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map((tag) => (
          <span class:list={[
            'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium',
            tag.variant === 'green' && 'bg-visdom-green text-white',
            tag.variant === 'outline' && 'border border-visdom-gray-300 text-visdom-gray-600',
            (!tag.variant || tag.variant === 'gray') && 'bg-visdom-gray-100 text-visdom-gray-600',
          ]}>
            {tag.label}
          </span>
        ))}
      </div>
    )}

    <!-- Title -->
    <h1 class="!mb-2">{title}</h1>
    {subtitle && <p class="text-lg text-visdom-gray-500 mb-10 !mt-0">{subtitle}</p>}

    <div class="border-b border-visdom-gray-200 mb-10"></div>

    <!-- Content -->
    <article>
      <slot />
    </article>

    <!-- Pagination -->
    {(prev || next) && (
      <nav class="border-t border-visdom-gray-200 mt-16 pt-8 flex justify-between">
        {prev ? (
          <a href={prev.href} class="group inline-flex items-center gap-2 text-sm text-visdom-gray-500 hover:text-visdom-green no-underline">
            <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
            <span>&larr; {prev.label}</span>
          </a>
        ) : <div />}
        {next ? (
          <a href={next.href} class="group inline-flex items-center gap-2 text-sm text-visdom-gray-500 hover:text-visdom-green no-underline">
            <span>{next.label} &rarr;</span>
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg>
          </a>
        ) : <div />}
      </nav>
    )}
  </main>

  <!-- Footer -->
  <footer class="mt-12">
    <div class="max-w-5xl mx-auto px-6 py-8 text-center text-xs text-visdom-gray-400">
      Visdom Code Review · Powered by <a href="https://virtuslab.com" class="text-visdom-gray-400 hover:text-visdom-green no-underline">VirtusLab</a>
    </div>
  </footer>
</body>
</html>
